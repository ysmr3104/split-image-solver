{
  "astrometry_local": {
    "solve_field_path": null,
    "timeout": 600,
    "search_radius": 10.0
  },
  "splitting": {
    "default_grid": "3x3",
    "default_overlap_pixels": 100,
    "min_overlap_pixels": 50,
    "max_overlap_pixels": 500
  },
  "wcs_integration": {
    "method": "weighted_least_squares",
    "overlap_tolerance_arcsec": 5.0,
    "control_points_per_tile": 25,
    "enable_distortion_correction": false
  },
  "python": {
    "script_path": "./python/main.py",
    "python_executable": "python3"
  },
  "logging": {
    "level": "INFO",
    "file_path": "/tmp/split_image_solver.log",
    "console_output": true
  },
  "temp_files": {
    "keep_on_error": true,
    "keep_on_success": false,
    "directory": "/tmp/split_image_solver"
  }
}
